{
  "permissions": {
    "allow": [
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)",
      "Skill(*)",
      "Task(*)",
      "TaskCreate(*)",
      "TaskUpdate(*)",
      "TaskGet(*)",
      "TaskList(*)",
      "TaskOutput(*)",
      "TaskStop(*)",
      "AskUserQuestion(*)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git blame *)"
    ],
    "ask": [
      "WebSearch(*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(npm install *)",
      "Bash(npm add *)",
      "Bash(pnpm install *)",
      "Bash(pnpm add *)",
      "Bash(yarn add *)"
    ],
    "deny": [
      "Bash(rm -rf /)*",
      "Bash(rm -rf ~)*",
      "Bash(rm -rf .)*",
      "Bash(rm -r .)*",
      "Bash(rm -r ./)*",
      "Bash(rm -rf *)*",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(curl*|*sh)*",
      "Bash(wget*|*sh)*",
      "Bash(*>~/.ssh/*)",
      "Bash(*>~/.bashrc)*",
      "Bash(*>~/.profile)*",
      "Bash(git push --force*main)*",
      "Bash(git push -f*main)*",
      "Bash(git push --force*master)*",
      "Bash(git push -f*master)*",
      "Bash(git reset --hard *)*",
      "Bash(git clean -f*)*",
      "Bash(git checkout -- .)*",
      "Bash(git restore .)*",
      "Bash(git push *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(npm publish)*",
      "Bash(eval *)*",
      "Bash(bash -c *)*",
      "Bash(sh -c *)*",
      "Read(./.git/**)",
      "Edit(./.git/**)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Edit(./.env)",
      "Edit(./.env.*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/db-guard.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": ".claude/hooks/remote-command-guard.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/secret-filter.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/security-auto-trigger.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": ".claude/hooks/code-quality-reminder.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-wrap-suggest.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/notify.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
